rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net: Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email == 'aceknight790@gmail.com' && request.auth.token.email_verified == true) ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // Entity Validations

    function isValidRepair(data) {
      return data.id is string && data.id.size() <= 64
        && data.name is string && data.name.size() <= 128
        && data.phone is string && data.phone.size() <= 32
        && (!data.keys().hasAll(['email']) || data.email is string)
        && data.productName is string && data.productName.size() <= 128
        && (!data.keys().hasAll(['modelSerial']) || data.modelSerial is string)
        && data.problem is string && data.problem.size() <= 1000
        && (!data.keys().hasAll(['method']) || data.method is string)
        && data.ref is string && data.ref.size() <= 32
        && data.status in ['Received', 'Diagnosed', 'Sent Away', 'In Repair', 'Returned', 'Ready for Pickup']
        && (!data.keys().hasAll(['aiComplexity']) || data.aiComplexity is string)
        && (!data.keys().hasAll(['aiCategory']) || data.aiCategory is string)
        && data.submittedAt is string;
    }

    function hasValidRepairKeys(data) {
      return data.keys().hasAll(['id', 'name', 'phone', 'productName', 'problem', 'ref', 'status', 'submittedAt'])
        && data.keys().size() >= 8 && data.keys().size() <= 14;
    }

    function isValidGMRequest(data) {
      return data.id is string && data.id.size() <= 64
        && data.type is string && data.type.size() <= 64
        && data.message is string && data.message.size() <= 5000
        && data.name is string && data.name.size() <= 128
        && data.phone is string && data.phone.size() <= 32
        && (!data.keys().hasAll(['preferredTime']) || data.preferredTime is string)
        && data.status in ['pending', 'resolved']
        && data.timestamp is string;
    }

    function hasValidGMRequestKeys(data) {
      return data.keys().hasAll(['id', 'type', 'message', 'name', 'phone', 'status', 'timestamp'])
        && (data.keys().size() == 7 || (data.keys().size() == 8 && data.keys().hasAll(['preferredTime'])));
    }

    function isValidFeedback(data) {
      return data.id is string && data.id.size() <= 64
        && data.name is string && data.name.size() <= 128
        && data.rating is int && data.rating >= 1 && data.rating <= 5
        && data.comment is string && data.comment.size() <= 2000
        && data.timestamp is string;
    }

    function hasValidFeedbackKeys(data) {
      return data.keys().hasAll(['id', 'name', 'rating', 'comment', 'timestamp'])
        && data.keys().size() == 5;
    }

    function isValidPickupSchedule(data) {
      return data.id is string && data.id.size() <= 64
        && data.name is string && data.name.size() <= 128
        && data.phone is string && data.phone.size() <= 32
        && data.items is string && data.items.size() <= 1000
        && data.date is string && data.date.size() <= 32
        && data.timeSlot is string && data.timeSlot.size() <= 64
        && data.status in ['scheduled', 'completed', 'cancelled']
        && data.timestamp is string;
    }

    function hasValidPickupKeys(data) {
      return data.keys().hasAll(['id', 'name', 'phone', 'items', 'date', 'timeSlot', 'status', 'timestamp'])
        && data.keys().size() == 8;
    }

    function isValidOrder(data) {
      return data.id is string && data.id.size() <= 64
        && data.customerName is string && data.customerName.size() <= 128
        && data.phone is string && data.phone.size() <= 32
        && (!data.keys().hasAll(['email']) || data.email is string)
        && data.items is string && data.items.size() <= 5000
        && (data.total is number || data.total is int)
        && data.paid is bool
        && (!data.keys().hasAll(['receiptUrl']) || data.receiptUrl is string)
        && data.timestamp is string
        && data.status in ['Pending Payment', 'Paid & Awaiting Processing', 'Processed & Ready', 'Dispatched/Completed'];
    }

    function hasValidOrderKeys(data) {
      return data.keys().hasAll(['id', 'customerName', 'phone', 'items', 'total', 'paid', 'timestamp', 'status'])
        && data.keys().size() >= 8 && data.keys().size() <= 10;
    }

    function isValidShadowSchoolApplication(data) {
      return data.id is string && data.id.size() <= 64
        && data.name is string && data.name.size() <= 128
        && data.phone is string && data.phone.size() <= 32
        && data.email is string && data.email.size() <= 128
        && data.age is int && data.age >= 10 && data.age <= 120
        && data.program in ['Computer Repairs', 'Digital Marketing', 'Solar Repairs', 'Entrepreneurship']
        && data.reason is string && data.reason.size() <= 2000
        && data.timestamp is string;
    }

    function hasValidShadowSchoolKeys(data) {
      return data.keys().hasAll(['id', 'name', 'phone', 'email', 'age', 'program', 'reason', 'timestamp'])
        && data.keys().size() == 8;
    }

    function isValidEscalation(data) {
      return data.id is string && data.id.size() <= 64
        && data.name is string && data.name.size() <= 128
        && data.phone is string && data.phone.size() <= 32
        && (!data.keys().hasAll(['email']) || data.email is string)
        && (!data.keys().hasAll(['ref']) || data.ref is string)
        && data.desc is string && data.desc.size() <= 5000
        && data.urgency is string && data.urgency.size() <= 64
        && (data.timestamp is int || data.timestamp is number);
    }

    function hasValidEscalationKeys(data) {
      return data.keys().hasAll(['id', 'name', 'phone', 'desc', 'urgency', 'timestamp'])
        && (data.keys().size() == 6 || (data.keys().size() == 7 && (data.keys().hasAll(['email']) || data.keys().hasAll(['ref']))) || (data.keys().size() == 8 && data.keys().hasAll(['email', 'ref'])));
    }

    function isValidGalleryImage(data) {
      return data.title is string && data.title.size() <= 200
        && data.url is string && data.url.size() <= 10000
        && data.caption is string && data.caption.size() <= 1000
        && data.timestamp is string;
    }

    function hasValidGalleryImageKeys(data) {
      return data.keys().hasAll(['title', 'url', 'caption', 'timestamp'])
        && data.keys().size() == 4;
    }

    function isValidReceipt(data) {
      return data.id is string && data.id.size() <= 64
        && data.orderId is string && data.orderId.size() <= 64
        && data.customerName is string && data.customerName.size() <= 128
        && (data.total is number || data.total is int)
        && data.timestamp is string;
    }

    function hasValidReceiptKeys(data) {
      return data.keys().hasAll(['id', 'orderId', 'customerName', 'total', 'timestamp'])
        && data.keys().size() == 5;
    }

    // Collection Rules

    match /repairs/{repairId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(repairId) && hasValidRepairKeys(incoming()) && isValidRepair(incoming()) && incoming().status == 'Received';
      allow update, delete: if isAdmin();
    }

    match /gm_requests/{requestId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(requestId) && hasValidGMRequestKeys(incoming()) && isValidGMRequest(incoming()) && incoming().status == 'pending';
      allow update, delete: if isAdmin();
    }

    match /feedback/{feedbackId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(feedbackId) && hasValidFeedbackKeys(incoming()) && isValidFeedback(incoming());
      allow update, delete: if isAdmin();
    }

    match /pickups/{pickupId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(pickupId) && hasValidPickupKeys(incoming()) && isValidPickupSchedule(incoming()) && incoming().status == 'scheduled';
      allow update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(orderId) && hasValidOrderKeys(incoming()) && isValidOrder(incoming());
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if true;
    }

    match /settings/{settingId} {
      allow read, write: if isSignedIn();
    }

    match /admins/{adminId} {
      allow read: if true;
      allow write: if isSignedIn() && adminId == request.auth.uid;
    }

    match /shadow_school_applications/{applicationId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(applicationId) && hasValidShadowSchoolKeys(incoming()) && isValidShadowSchoolApplication(incoming());
      allow update, delete: if isAdmin();
    }

    match /escalations/{escalationId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(escalationId) && hasValidEscalationKeys(incoming()) && isValidEscalation(incoming());
      allow update, delete: if isAdmin();
    }

    match /gallery_images/{imageId} {
      allow read, list: if true;
      allow create, update: if isSignedIn() && isValidId(imageId) && hasValidGalleryImageKeys(incoming()) && isValidGalleryImage(incoming());
      allow delete: if isAdmin();
    }

    match /receipts/{receiptId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(receiptId) && hasValidReceiptKeys(incoming()) && isValidReceipt(incoming());
      allow update, delete: if isAdmin();
    }
  }
}
